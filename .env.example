# ──────────────────────────────────────────────────────────────────────────────
# PaalStack Next.js Starter — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEXT_PUBLIC_* variables are exposed to the browser.
# All variables are validated at startup via @t3-oss/env-nextjs + Zod.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="PaalStack"

# Enable verbose debug logging in the browser console (true | false)
NEXT_PUBLIC_DEBUG_MODE=false

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and keys from:
# https://supabase.com/dashboard/project/<id>/settings/api

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co

# Publishable (anon) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — server-only, bypasses RLS (never expose to browser)
SUPABASE_SECRET_KEY=sb_secret_...

# Personal access token — used only by migration scripts, never sent to browser
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ── Backend API ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/v1

# ── Email ──────────────────────────────────────────────────────────────────────
# Resend API key — server-only, never expose to browser
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
