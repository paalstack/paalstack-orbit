{
  // ── Editor ──────────────────────────────────────────────────────────────
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.rulers": [
    100
  ],
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.stickyScroll.enabled": true,
  "editor.suggest.insertMode": "replace",
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit",
    "source.addMissingImports": "explicit"
  },
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[mdx]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // ── Files ────────────────────────────────────────────────────────────────
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  // ── TypeScript ───────────────────────────────────────────────────────────
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.quoteStyle": "single",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.returnTypes.enabled": false,
  "typescript.inlayHints.variableTypes.enabled": false,
  // ── ESLint (v9 flat config) ──────────────────────────────────────────────
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "markdown",
    "mdx"
  ],
  // ── Prettier ─────────────────────────────────────────────────────────────
  "prettier.prettierPath": "./node_modules/prettier/index.cjs",
  // ── Tailwind CSS ─────────────────────────────────────────────────────────
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascriptreact"
  },
  "tailwindCSS.experimental.classRegex": [
    [
      "cva\\(([^)]*)\\)",
      "[\"'`]([^\"'`]*).*?[\"'`]"
    ],
    [
      "cn\\(([^)]*)\\)",
      "[\"'`]([^\"'`]*).*?[\"'`]"
    ]
  ],
  // ── Search ───────────────────────────────────────────────────────────────
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/playwright-report": true,
    "pnpm-lock.yaml": true
  },
  // ── Explorer file nesting ────────────────────────────────────────────────
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "next.config.*": "next-env.d.ts, .env, .env.*",
    "package.json": "pnpm-lock.yaml, .npmrc, .nvmrc, .node-version, .tool-versions",
    "tsconfig.json": "tsconfig.*.json",
    "eslint.config.*": ".eslintignore",
    "prettier.config.*": ".prettierignore",
    "tailwind.config.*": "postcss.config.*",
    "playwright.config.*": "playwright-report",
    "vitest.config.*": "vitest.setup.*"
  },
  // ── MDX ──────────────────────────────────────────────────────────────────
  "mdx.experimentalLanguageServer": true,
  // ── Spell checker ────────────────────────────────────────────────────────
  "cSpell.words": [
    "clsx",
    "Combobox",
    "commitizen",
    "commitlint",
    "csstype",
    "husky",
    "nextjs",
    "paalstack",
    "Paalstack",
    "playwright",
    "pnpm",
    "supabase",
    "tailwindcss",
    "tanstack",
    "treeshake",
    "tsup",
    "turbopack",
    "vitest",
    "zustand"
  ]
}
