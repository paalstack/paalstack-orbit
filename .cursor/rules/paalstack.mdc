## @paalstack/react-ui/lib — server-safe utilities

```tsx
import { cn, logger, httpClient, dateIntl, currencyIntl, numberIntl } from '@paalstack/react-ui/lib';

// cn — class merging (clsx + tailwind-merge)
cn('px-4 py-2', isActive && 'bg-primary', 'px-6') // → 'py-2 bg-primary px-6'

// logger
logger.info('User signed in', { userId });
logger.error('API failed', error);

// httpClient (Axios-based)
const data = await httpClient.get<User>('/api/users/1');
await httpClient.post<User>('/api/users', { name: 'Alice' });

// Formatters (standalone, no provider needed)
dateIntl.format(new Date());      // '06/23/2026'
currencyIntl.format(1234.56);     // '$1,234.56'
numberIntl.format(1234567.89);    // '1,234,567.89'

// Error classes
import { InternalServerException, ResourceNotFoundException } from '@paalstack/react-ui/lib';
throw new InternalServerException({ message: 'Something went wrong' });
```
