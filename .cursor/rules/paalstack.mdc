## @paalstack/react-hooks — client-only

All hooks require `'use client'`.

```tsx
'use client';
import { useToggle, useCounter, useDisclosure, useLocalStorage } from '@paalstack/react-hooks';

const [isOpen, { open, close, toggle }] = useToggle(false);
const [count, { increment, decrement, reset }] = useCounter(0);
const { isOpen, onOpen, onClose, onToggle } = useDisclosure();
const [theme, setTheme] = useLocalStorage('theme', 'light');

// Also available:
// useDebouncedValue · useDebouncedState · useSessionStorage · useClickOutside
// useClipboard · useIntersection · useMediaQuery · useWindowScroll · useElementSize
// usePrevious · useHotkeys · usePagination · useFocusTrap · useIdle · useHash
// useDocumentTitle · useInterval · useTimeout · useOs · useReducedMotion
// useQueue · useListState
```

