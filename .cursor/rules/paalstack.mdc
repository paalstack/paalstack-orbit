## Providers

All providers from `@paalstack/react-ui`. Do **not** import from `@paalstack/react-providers` directly.

### NextThemeProvider — Next.js only (includes ToastProvider — no separate `<Toaster>` needed)

```tsx
// src/app/layout.tsx — Server Component, no 'use client'
import { NextThemeProvider, FormatIntlProvider } from '@paalstack/react-ui';
import { QueryProvider } from '@/providers/query-provider';

export default function RootLayout({ children }: { children: React.ReactNode }) {
  return (
    <html lang="en" suppressHydrationWarning>
      <body>
        <NextThemeProvider attribute="class" defaultTheme="system" enableSystem disableTransitionOnChange>
          <FormatIntlProvider countryBasedFormatKey="US">
            <QueryProvider>{children}</QueryProvider>
          </FormatIntlProvider>
        </NextThemeProvider>
      </body>
    </html>
  );
}
```

### useNextTheme — Client Component

```tsx
'use client';
import { useNextTheme } from '@paalstack/react-ui';

const { isDark, resolvedTheme, setTheme } = useNextTheme();
setTheme(isDark ? 'light' : 'dark');
```

### FormatIntlProvider / useFormatIntl

```tsx
'use client';
import { useFormatIntl } from '@paalstack/react-ui';

const { dateIntl, currencyIntl, numberIntl, t } = useFormatIntl();
dateIntl.format(new Date());          // '06/23/2026'
currencyIntl.format(1234.56);         // '$1,234.56'
numberIntl.format(0.45, { style: 'percent' }); // '45%'
```

### Toast

```tsx
'use client';
import { toast } from '@paalstack/react-ui';

toast.success('Saved!');
toast.error('Something went wrong.');
toast.info('3 items updated.');
toast.promise(saveData(), { loading: 'Saving...', success: 'Saved!', error: 'Error.' });
```

