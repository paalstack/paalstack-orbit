{
  "name": "paalstack-orbit",
  "version": "0.1.0",
  "description": "PaalStack Orbit — CRM and workflow automation platform built on Next.js 16, Supabase, TanStack Query, and @paalstack/react-ui",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "analyze": "next experimental-analyze",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0 --no-warn-ignored --cache",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md,mdx}\" --cache",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md,mdx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "commit": "cz",
    "clean": "rm -rf .next node_modules/.cache",
    "clean:all": "rm -rf .next node_modules pnpm-lock.yaml"
  },
  "keywords": [
    "nextjs",
    "nextjs-16",
    "react",
    "react-19",
    "typescript",
    "tailwindcss",
    "tailwind-css-v4",
    "supabase",
    "tanstack-query",
    "zustand",
    "zod",
    "react-hook-form",
    "vitest",
    "playwright",
    "paalstack",
    "boilerplate",
    "starter",
    "template",
    "saas",
    "enterprise",
    "app-router",
    "server-components",
    "turbopack"
  ],
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@paalstack/react-hooks": "^1.1.1",
    "@paalstack/react-icons": "^1.1.0",
    "@paalstack/react-ui": "^1.2.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^16.2.9",
    "nextjs-toploader": "^3.9.17",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.9.0",
    "resend": "^6.16.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.1",
    "@commitlint/cz-commitlint": "^17.6.7",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/ui": "^4.0.18",
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^15.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "author": {
    "name": "Paalamugan",
    "email": "paalamugan@paalstack.com"
  },
  "license": "MIT",
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
